{:lexicon 1,
 :id "com.etzhayyim.kizashi.modalityCapability",
 :description
 "PUBLIC modality capability ledger entry (kotoba-EAVT; NOT encrypted — this is the honesty registry). G10 STRUCTURAL: evidenceGrade + regulatoryClass + canDetect + cannotDetect are REQUIRED. A modality without a ledger entry cannot emit a modalityObservation. Anti-pseudoscience: bio-resonance / aura / 全身波動 / quantum scanners are EXCLUDED (cannot be ledgered with a defensible evidence grade).",
 :defs
 {:main
  {:type "record",
   :key "tid",
   :record
   {:type "object",
    :required
    ["createdAt"
     "modalityId"
     "evidenceGrade"
     "regulatoryClass"
     "canDetect"
     "cannotDetect"
     "councilAttestationCid"],
    :properties
    {:evidenceGrade
     {:type "string",
      :knownValues
      ["A-validated-clinical"
       "B-emerging-peer-reviewed"
       "C-screening-only"
       "X-excluded-pseudoscience"],
      :description
      "G10 REQUIRED: declared evidence grade. X entries are recorded ONLY to explicitly document exclusion; they may never emit observations."},
     :councilAttestationCid
     {:type "string",
      :description
      "G10 REQUIRED: Council ratification of the evidence grade + regulatory class for this modality"},
     :displayName {:type "string"},
     :charterRiderScanPass {:type "boolean"},
     :createdAt {:type "string", :format "datetime"},
     :regulatoryClass
     {:type "string",
      :knownValues
      ["non-regulated-wellness"
       "samd-software"
       "regulated-medical-device"
       "ionizing-licensed-facility-only"],
      :description
      "G4/G9 REQUIRED: regulated / ionizing classes are R3-gated to a licensed-medical-device pathway"},
     :cannotDetect
     {:type "array",
      :items {:type "string"},
      :description
      "Honest limit: what this modality CANNOT sense (e.g. 'thermography cannot identify allergens', 'optical cannot see internal structure')"},
     :phaseGate
     {:type "string",
      :knownValues ["R1" "R2" "R3"],
      :description "Earliest phase this modality may be used"},
     :modalityId {:type "string"},
     :canDetect
     {:type "array",
      :items {:type "string"},
      :description
      "Honest capability: what signs this modality CAN sense (e.g. posture asymmetry, surface circulation, muscle stiffness)"},
     :ionizing
     {:type "boolean",
      :description
      "G9: true → never a routine-pod modality; referral-to-licensed-facility only"}}}}}}
