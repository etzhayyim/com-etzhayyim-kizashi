  "form": "任意団体 internal non-invasive sensing/screening substrate (NOT 一般社団 / NPO / 公益財団 / 宗教法人 法人格 — Preamble §0.4 Lv7+ unanimity lock)",
  "privacyInvariant": {
    "encryptedEnvelope": "MANDATORY per ADR-2605181100; structural Lexicon enforcement at R1 (scanSessionAttestation + modalityObservation + wellbecomingTrajectory MUST carry encryptedPayloadCid; additionalProperties=false). Biometric scan = 要配慮個人情報 (APPI special-care).",
    "rotatingPseudonym": "30-day rotating pseudonym DID per ADR-2605181200 (scan features ≠ stable identity; no biometric-identity database, N10)",
    "noPlaintextFeatures": "signal_fusion holds fused features transient-only; never write plaintext feature vectors to disk",
    "rationale": "Biometric scan data is 要配慮 PII and the most sensitive observation class alongside clinical PHI; structural enforcement, not policy."
  },
  "constitutionalDiscipline": {
    "nonDiagnostic": "G3 — 医師法 §17 boundary; outputs 兆候 + probabilistic attribution + consult recommendation ONLY; never diagnosis/treatment/adjudication; licensed clinician (mitate/iyashi) owns any diagnosis",
    "medicalDeviceBoundary": "G4 — 薬機法/PMDA/SaMD; R0..R2 = software + simulation + non-ionizing non-regulated sensing only; regulated/energy-emitting modalities gated to licensed-device pathway + qualified operator + Council Lv7+ (R3)",
    "verifiedModalityOnly": "G10 — only modalities in modalityCapability ledger with declared evidence grade may emit; bio-resonance / aura / 全身波動 / quantum scanners EXCLUDED",
    "selfReferencedWellbecoming": "G8 — compare to member's OWN prior trajectory; no population ranking / health-score leaderboard (anti-individualist 動的軌跡)",
    "uncertaintyHonest": "G7 — every attribution carries calibrated confidence + 所見≠確定原因 disclaimer; structural",
    "noCommercialImagingCloud": "G12 — PACS / diagnostic-SaaS / commercial imaging-AI cloud PROHIBITED (Charter Rider §2(e)+§2(c)); kotoba-native",
    "noPayrollForOperators": "G13 — operators are vocation-flow L5 stewards; toritate.ledgerEntry.category excludes payroll/wage/salary/bonus/commission",
    "murakumoOnlyInference": "G14 — Murakumo-only inference per ADR-2605215000; vendor medical-AI PROHIBITED"
  },
  "modalityCapabilityLedgerSeed": "registry/modalities.seed.json — 14 modalities (11 sensing + MRI/CT referral marker + 3 grade-X excluded pseudoscience); each binds evidenceGrade + regulatoryClass + canDetect/cannotDetect + ionizing + phaseGate; all verificationStatus=unverified-seed (G10 Council-ratify before R1 emission). R0..R2 may use ONLY phaseGate∈{R1,R2} + non-regulated-wellness + ionizing=false (optical-posture-3d / markerless-gait / infrared-thermography / bioimpedance).",
  "scope": {
    "phase": "R0 scaffold",
    "scopeBoundary": "Non-invasive multimodal capture → fusion → probabilistic non-diagnostic attribution → self-referenced Wellbecoming trajectory → triage referral; modality capability ledger",
    "exclusions": [
      "diagnosis (mitate + licensed clinician)",
      "treatment (iyashi + yakushi)",
      "allergen identification by imaging (biochemistry; microsampling only, not 'scanning' allergens)",
      "replacement for clinical MRI/CT/PET in licensed facilities",
      "population health-score / ranking / leaderboard",
      "法定健診 / statutory health-check / insurance product",
      "commercial wellness-pod product (no SaaS sale)",
      "pseudoscience modalities (bio-resonance / aura / 波動 / quantum)",
      "involuntary / surveillance scanning",
      "biometric-identity database",
      "genetic testing",
      "minors / incapacitated without guardian + hagukumi consent"
    ]
  },
