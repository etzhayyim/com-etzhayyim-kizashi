  "@type": "ActorManifest",
  "id": "did:web:kizashi.etzhayyim.com",
  "name": "kizashi",
  "displayName": "兆 — Non-invasive Multimodal Body-Scan / Sign-Sensing",
  "displayNameJa": "兆",
  "displayNameEn": "Kizashi",
  "description": "Non-profit religious-corp non-invasive multimodal body-scan / sign-sensing substrate — the 'futuristic scan pod' sensing/instrument layer of the L4 Care Tier. Senses physical-burden SIGNS (腰痛 posture/筋, 肩こり 筋硬度/血流, 鼻詰まり 構造/気流, アレルギー via consented microsampling, 炎症 thermal/biomarker) via multimodal capture → fusion → PROBABILISTIC NON-DIAGNOSTIC attribution + self-referenced Wellbecoming trajectory + triage referral. kizashi SENSES → mitate DIAGNOSES → iyashi TREATS. NON-DIAGNOSTIC (G3, 医師法 §17). Medical-device regulatory boundary (G4, 薬機法/SaMD — R0..R2 software+simulation+non-ionizing non-regulated only; regulated/ionizing modalities R3-gated). Encrypted biometric envelope MANDATORY (G2, 要配慮 PII per ADR-2605181100). Verified-modality-only / anti-pseudoscience (G10; bio-resonance/aura/波動 EXCLUDED). Self-referenced Wellbecoming (G8; no population ranking). Murakumo-only inference (G14). 6 cells / 6 Lexicons / 14 gates / 12 non-goals. Cross-actor: mitate (sign→diagnosis) / iyashi (clinical) / kokoro (psychosocial) / yakushi (medication via iyashi) / hagukumi (consent) / chigiri (consent+steward) / toritate (Public Fund grant) / manabi (operator training).",
  "descriptionJa": "非営利 religious-corp の非侵襲マルチモーダル身体スキャン / 兆候センシング substrate — 未来的「スキャンポッド」の sensing/instrument 層 (L4 Care Tier)。身体的負担の兆候 (腰痛 姿勢/筋, 肩こり 筋硬度/血流, 鼻詰まり 構造/気流, アレルギー consented microsampling 経由, 炎症 thermal/biomarker) を マルチモーダル取得 → 融合 → 確率的・非診断的 attribution + 自己参照 Wellbecoming 軌跡 + triage 紹介。kizashi が兆候を感知 → mitate が診断 → iyashi が治療。非診断 (G3, 医師法 §17)。医療機器規制境界 (G4, 薬機法/SaMD — R0..R2 は software+simulation+非電離・非規制 のみ; 規制/電離 modality は R3 gated)。暗号化エンベロープ必須 (G2; 生体スキャン = 要配慮個人情報)。検証済み modality のみ / 反疑似科学 (G10; bio-resonance/aura/波動 除外)。自己参照 Wellbecoming (G8; 集団ランキングなし)。Murakumo only inference (G14)。",
  "adr": {
    "master": "etzhayyim:adr:2605312700",
    "parent": "etzhayyim:adr:2605261000",
    "r0": "etzhayyim:adr:2605312700",
    "r1": "reserved",
    "r2": "reserved",
    "r3": "reserved"
  },
  "tier": "Tier-B",
  "parentActor": null,
  "liberationLadderGate": "L4",
  "roleInTier": "sensing/instrument layer — UPSTREAM of all clinical adjudication (kizashi senses → mitate diagnoses → iyashi treats)",
  "siblingsAtL4": [
    "did:web:mitate.etzhayyim.com (diagnostic routing — TIGHT pair)",
    "did:web:iyashi.etzhayyim.com (clinical care provider)",
    "did:web:kokoro.etzhayyim.com (mental health support)",
    "did:web:yakushi.etzhayyim.com (pharmaceutical manufacturing)",
    "did:web:hagukumi.etzhayyim.com (daily-living care)"
  ],
  "crossActorPair": {
    "mitate": "TIGHT pair — sign → diagnosis; kizashi senses, mitate (licensed clinician) reads; G5 emergency keyword shared",
    "iyashi": "clinical-encounter referral after sign-sensing",
    "kokoro": "psychosocial referral — pain (腰痛/肩こり) is multifactorial; biopsychosocial routing",
    "yakushi": "medication supply via iyashi only (kizashi never prescribes)",
    "hagukumi": "minor / elder / incapacitated consent + daily-living continuity",
    "chigiri": "consentRecord (scan consent) + stewardLaborAttestation (operator L5 vocation-flow)",
    "toritate": "Public Fund grant accounting (no fee-for-scan, G13)",
    "manabi": "operator training + capability-ledger evidence-grade literacy"
