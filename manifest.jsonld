  "constitutionalGates": {
    "description": "14 immutable gates per ADR-2605312700. Council Lv6+ supermajority + new ADR to amend.",
    "gates": {
      "G1": "Charter Rider §2(a)-(h) scan on every emitted document",
      "G2": "Encrypted envelope MANDATORY (biometric scan = 要配慮 PII per ADR-2605181100); encryptedPayloadCid required, plaintext rejected at schema layer",
      "G3": "NON-DIAGNOSTIC (医師法 §17) — 兆候 + probabilistic attribution + consult recommendation ONLY; never diagnosis/treatment/adjudication",
      "G4": "Medical-device regulatory boundary (薬機法/PMDA/SaMD) — R0..R2 software+simulation+non-ionizing non-regulated only; regulated modalities R3-gated to licensed pathway + qualified operator + Council Lv7+",
      "G5": "Emergency red-flag escalation — shared keyword lexicon with mitate/iyashi/kokoro; red-flag → immediate 受診/救急, never 'wait for next scan'",
      "G6": "Per-scan consent (default-deny, revocable, scope-bound; APPI 要配慮 explicit consent; minors via guardian + hagukumi)",
      "G7": "Uncertainty-honest / no false precision — every attribution carries calibrated confidence + 所見≠確定原因 disclaimer (structural)",
      "G8": "Self-referenced Wellbecoming — compare to member's OWN prior trajectory; no population ranking / health-score leaderboard",
      "G9": "Energy minimization / ALARA — prefer non-ionizing; no casual ionizing radiation; ionizing = referral to licensed facility, never routine pod",
      "G10": "Verified-modality-only / anti-pseudoscience — only modalities in capability ledger with declared evidence grade may emit; bio-resonance/aura/波動/quantum EXCLUDED",
      "G11": "Outward-gated — real hardware pod + real member scans require Council + licensed oversight + R3; R0 design-only",
      "G12": "No commercial medical-imaging cloud / PACS / diagnostic-SaaS / commercial imaging-AI (Charter Rider §2(e)+§2(c)); kotoba-native",
      "G13": "No payroll for operators (vocation-flow L5 stewards)",
      "G14": "Murakumo-only inference (no vendor medical-AI)"
    }
  },
  "nonGoals": {
    "description": "12 explicitly excluded scopes",
    "goals": {
      "N1": "NOT a diagnosis (医師法 — mitate + licensed clinician)",
      "N2": "NOT a treatment device (iyashi + yakushi)",
      "N3": "NOT allergen identification by imaging (biochemistry; microsampling not 'scanning')",
      "N4": "NOT a replacement for clinical MRI/CT/PET in licensed facilities",
      "N5": "NOT a population health-score / ranking / leaderboard",
      "N6": "NOT a 法定健診 / statutory health-check substitute / insurance",
      "N7": "NOT a commercial wellness-pod product (no SaaS sale)",
      "N8": "NOT pseudoscience modalities (bio-resonance / aura / 全身波動 / quantum)",
      "N9": "NOT involuntary / surveillance scanning",
      "N10": "NOT a biometric-identity database (30-day rotating pseudonym DID)",
      "N11": "NOT genetic testing (separate gated domain)",
      "N12": "NOT for minors / incapacitated without guardian + hagukumi consent"
    }
  },
